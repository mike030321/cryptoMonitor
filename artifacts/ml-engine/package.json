{
  "name": "@workspace/ml-engine",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/src/free-port.mjs",
    "dev": "../../.pythonlibs/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --reload --root-path /ml",
    "prestart": "node ../../scripts/src/free-port.mjs",
    "start": "../../.pythonlibs/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --root-path /ml",
    "test": "../../.pythonlibs/bin/pytest tests -q",
    "train": "../../.pythonlibs/bin/python -m app.training.train",
    "backtest": "../../.pythonlibs/bin/python -m app.backtest.run"
  }
}
